{
  "version": 2,
  "functions": {
    "api/start.js":  { "maxDuration": 10 },
    "api/stop.js":   { "maxDuration": 10 },
    "api/status.js": { "maxDuration": 10 },
    "api/otp.js":    { "maxDuration": 10 }
  },
  "routes": [
    { "src": "/start",  "dest": "/api/start.js"  },
    { "src": "/stop",   "dest": "/api/stop.js"   },
    { "src": "/status", "dest": "/api/status.js" },
    { "src": "/otp",    "dest": "/api/otp.js"    }
  ]
}
